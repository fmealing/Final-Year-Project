{
  "name": "metro-source-map",
  "version": "0.82.5",
  "description": "🚇 Source map generator for Metro.",
  "main": "src/source-map.js",
  "exports": {
    ".": "./src/source-map.js",
    "./package.json": "./package.json",
    "./private/*": "./src/*.js",
    "./src/*.js": "./src/*.js",
    "./src/*": "./src/*.js",
    "./src/Consumer": "./src/Consumer/index.js",
    "./src/B64Builder.js": "./src/B64Builder.js",
    "./src/B64Builder": "./src/B64Builder.js",
    "./src/BundleBuilder.js": "./src/BundleBuilder.js",
    "./src/BundleBuilder": "./src/BundleBuilder.js",
    "./src/Consumer/AbstractConsumer.js": "./src/Consumer/AbstractConsumer.js",
    "./src/Consumer/AbstractConsumer": "./src/Consumer/AbstractConsumer.js",
    "./src/Consumer/DelegatingConsumer.js": "./src/Consumer/DelegatingConsumer.js",
    "./src/Consumer/DelegatingConsumer": "./src/Consumer/DelegatingConsumer.js",
    "./src/Consumer/MappingsConsumer.js": "./src/Consumer/MappingsConsumer.js",
    "./src/Consumer/MappingsConsumer": "./src/Consumer/MappingsConsumer.js",
    "./src/Consumer/SectionsConsumer.js": "./src/Consumer/SectionsConsumer.js",
    "./src/Consumer/SectionsConsumer": "./src/Consumer/SectionsConsumer.js",
    "./src/Consumer/constants.js": "./src/Consumer/constants.js",
    "./src/Consumer/constants": "./src/Consumer/constants.js",
    "./src/Consumer/createConsumer.js": "./src/Consumer/createConsumer.js",
    "./src/Consumer/createConsumer": "./src/Consumer/createConsumer.js",
    "./src/Consumer/index.js": "./src/Consumer/index.js",
    "./src/Consumer/index": "./src/Consumer/index.js",
    "./src/Consumer/normalizeSourcePath.js": "./src/Consumer/normalizeSourcePath.js",
    "./src/Consumer/normalizeSourcePath": "./src/Consumer/normalizeSourcePath.js",
    "./src/Consumer/positionMath.js": "./src/Consumer/positionMath.js",
    "./src/Consumer/positionMath": "./src/Consumer/positionMath.js",
    "./src/Consumer/search.js": "./src/Consumer/search.js",
    "./src/Consumer/search": "./src/Consumer/search.js",
    "./src/Consumer/types.flow.js": "./src/Consumer/types.flow.js",
    "./src/Consumer/types.flow": "./src/Consumer/types.flow.js",
    "./src/Generator.js": "./src/Generator.js",
    "./src/Generator": "./src/Generator.js",
    "./src/composeSourceMaps.js": "./src/composeSourceMaps.js",
    "./src/composeSourceMaps": "./src/composeSourceMaps.js",
    "./src/encode.js": "./src/encode.js",
    "./src/encode": "./src/encode.js",
    "./src/generateFunctionMap.js": "./src/generateFunctionMap.js",
    "./src/generateFunctionMap": "./src/generateFunctionMap.js",
    "./src/source-map.js": "./src/source-map.js",
    "./src/source-map": "./src/source-map.js"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:facebook/metro.git"
  },
  "scripts": {
    "prepare-release": "test -d build && rm -rf src.real && mv src src.real && mv build src",
    "cleanup-release": "test ! -e build && mv src build && mv src.real src"
  },
  "dependencies": {
    "@babel/traverse": "^7.25.3",
    "@babel/traverse--for-generate-function-map": "npm:@babel/traverse@^7.25.3",
    "@babel/types": "^7.25.2",
    "flow-enums-runtime": "^0.0.6",
    "invariant": "^2.2.4",
    "metro-symbolicate": "0.82.5",
    "nullthrows": "^1.1.1",
    "ob1": "0.82.5",
    "source-map": "^0.5.6",
    "vlq": "^1.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/parser": "^7.25.3",
    "terser": "^5.15.0"
  },
  "engines": {
    "node": ">=18.18"
  }
}