{
  "name": "metro-core",
  "version": "0.82.5",
  "description": "🚇 Metro's core package.",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./package.json": "./package.json",
    "./private/*": "./src/*.js",
    "./src": "./src/index.js",
    "./src/*.js": "./src/*.js",
    "./src/*": "./src/*.js",
    "./src/Logger.js": "./src/Logger.js",
    "./src/Logger": "./src/Logger.js",
    "./src/Terminal.js": "./src/Terminal.js",
    "./src/Terminal": "./src/Terminal.js",
    "./src/canonicalize.js": "./src/canonicalize.js",
    "./src/canonicalize": "./src/canonicalize.js",
    "./src/errors/AmbiguousModuleResolutionError.js": "./src/errors/AmbiguousModuleResolutionError.js",
    "./src/errors/AmbiguousModuleResolutionError": "./src/errors/AmbiguousModuleResolutionError.js",
    "./src/errors/PackageResolutionError.js": "./src/errors/PackageResolutionError.js",
    "./src/errors/PackageResolutionError": "./src/errors/PackageResolutionError.js",
    "./src/errors.js": "./src/errors.js",
    "./src/errors": "./src/errors.js",
    "./src/index.js": "./src/index.js",
    "./src/index": "./src/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:facebook/metro.git"
  },
  "scripts": {
    "prepare-release": "test -d build && rm -rf src.real && mv src src.real && mv build src",
    "cleanup-release": "test ! -e build && mv src build && mv src.real src"
  },
  "dependencies": {
    "flow-enums-runtime": "^0.0.6",
    "lodash.throttle": "^4.1.1",
    "metro-resolver": "0.82.5"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.18"
  }
}