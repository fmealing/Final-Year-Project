{
  "name": "metro-cache",
  "version": "0.82.5",
  "description": "🚇 Cache layers for Metro.",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./package.json": "./package.json",
    "./private/*": "./src/*.js",
    "./src": "./src/index.js",
    "./src/*.js": "./src/*.js",
    "./src/*": "./src/*.js",
    "./src/Cache.js": "./src/Cache.js",
    "./src/Cache": "./src/Cache.js",
    "./src/index.js": "./src/index.js",
    "./src/index": "./src/index.js",
    "./src/stableHash.js": "./src/stableHash.js",
    "./src/stableHash": "./src/stableHash.js",
    "./src/stores/AutoCleanFileStore.js": "./src/stores/AutoCleanFileStore.js",
    "./src/stores/AutoCleanFileStore": "./src/stores/AutoCleanFileStore.js",
    "./src/stores/FileStore.js": "./src/stores/FileStore.js",
    "./src/stores/FileStore": "./src/stores/FileStore.js",
    "./src/stores/HttpError.js": "./src/stores/HttpError.js",
    "./src/stores/HttpError": "./src/stores/HttpError.js",
    "./src/stores/HttpGetStore.js": "./src/stores/HttpGetStore.js",
    "./src/stores/HttpGetStore": "./src/stores/HttpGetStore.js",
    "./src/stores/HttpStore.js": "./src/stores/HttpStore.js",
    "./src/stores/HttpStore": "./src/stores/HttpStore.js",
    "./src/stores/NetworkError.js": "./src/stores/NetworkError.js",
    "./src/stores/NetworkError": "./src/stores/NetworkError.js",
    "./src/types.flow.js": "./src/types.flow.js",
    "./src/types.flow": "./src/types.flow.js"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:facebook/metro.git"
  },
  "scripts": {
    "prepare-release": "test -d build && rm -rf src.real && mv src src.real && mv build src",
    "cleanup-release": "test ! -e build && mv src build && mv src.real src"
  },
  "dependencies": {
    "exponential-backoff": "^3.1.1",
    "flow-enums-runtime": "^0.0.6",
    "https-proxy-agent": "^7.0.5",
    "metro-core": "0.82.5"
  },
  "devDependencies": {
    "metro-memory-fs": "0.82.5"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.18"
  }
}